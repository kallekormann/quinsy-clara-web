{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/how-to/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://*.monday.com https://monday.com"
        }
      ]
    },
    {
      "source": "/assets/(.*\\.mp4)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Content-Type",
          "value": "video/mp4"
        }
      ]
    }
  ]
}
